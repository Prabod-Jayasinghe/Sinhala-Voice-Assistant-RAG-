# ============================================================
# Sinhala Voice Assistant (RAG) — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is in .gitignore.

# ---- Groq API (STT — Whisper large-v3) ---------------------
GROQ_API_KEY=your_groq_api_key_here

# ---- Google Gemini (LLM — answer generation) ---------------
GEMINI_API_KEY=your_gemini_api_key_here

# ---- TTS: edge-tts -----------------------------------------
# No API key required — edge-tts uses Microsoft Edge's free browser TTS.
# Voice options for Sinhala:
#   si-LK-ThiliniNeural  (female)
#   si-LK-SameeraNeural  (male)
TTS_VOICE=si-LK-ThiliniNeural

# ---- Backend settings ---------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ---- Frontend (set this in Vercel env too) ------------------
# NEXT_PUBLIC_API_URL=https://your-render-backend.onrender.com
